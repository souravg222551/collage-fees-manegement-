// ============================================================
// College Fee Management — Prisma Schema (Neon PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------
// ADMIN
// ------------------------------------------------------------
enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Admin {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      AdminRole @default(ADMIN)
  avatarUrl String?
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  receipts FeePayment[] @relation("CollectedBy")

  @@map("admins")
}

// ------------------------------------------------------------
// STUDENT
// ------------------------------------------------------------
enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  DROPPED
}

model Student {
  id                String        @id @default(uuid())
  studentId         String        @unique // e.g. STU-2026-0001
  rollNumber        String        @unique
  enrollmentNumber  String        @unique
  photoUrl          String?
  firstName         String
  lastName          String
  fathersName       String
  mothersName       String
  dob               DateTime
  gender            Gender        @default(OTHER)
  mobile            String
  altMobile         String?
  email             String        @unique
  address           String?
  department        String
  course             String
  branch            String
  semester          Int
  section           String
  academicSession   String // e.g. "2025-2026"
  admissionDate     DateTime      @default(now())
  status            StudentStatus @default(ACTIVE)
  totalFeeAssigned  Decimal       @default(0) @db.Decimal(12, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  feePayments FeePayment[]

  @@index([department, course, branch, semester])
  @@index([academicSession])
  @@map("students")
}

// ------------------------------------------------------------
// FEE PAYMENT
// ------------------------------------------------------------
enum FeeType {
  TUITION
  EXAM
  HOSTEL
  TRANSPORT
  LIBRARY
  LAB
  MISCELLANEOUS
  ADMISSION
  OTHER
}

enum PaymentMode {
  CASH
  CARD
  UPI
  NET_BANKING
  CHEQUE
  BANK_TRANSFER
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
  CANCELLED
  REFUNDED
}

model FeePayment {
  id              String        @id @default(uuid())
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId       String
  feeType         FeeType       @default(TUITION)
  academicSession String
  semester        Int
  totalAmount     Decimal       @db.Decimal(12, 2) // amount due for this fee entry
  amountPaid      Decimal       @default(0) @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  scholarship     Decimal       @default(0) @db.Decimal(12, 2)
  fine            Decimal       @default(0) @db.Decimal(12, 2)
  balance         Decimal       @default(0) @db.Decimal(12, 2)
  paymentMode     PaymentMode   @default(CASH)
  status          PaymentStatus @default(PENDING)
  transactionRef  String?
  remarks         String?
  paidAt          DateTime      @default(now())
  dueDate         DateTime?
  collectedBy     Admin?        @relation("CollectedBy", fields: [collectedById], references: [id])
  collectedById   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  receipt Receipt?

  @@index([studentId])
  @@index([status])
  @@index([paidAt])
  @@map("fee_payments")
}

// ------------------------------------------------------------
// RECEIPT
// ------------------------------------------------------------
model Receipt {
  id            String     @id @default(uuid())
  receiptNumber String     @unique // e.g. RCPT-2026-000123
  feePayment    FeePayment @relation(fields: [feePaymentId], references: [id], onDelete: Cascade)
  feePaymentId  String     @unique
  qrCodeData    String?
  issuedAt      DateTime   @default(now())
  createdAt     DateTime   @default(now())

  @@map("receipts")
}

// ------------------------------------------------------------
// SETTINGS (singleton table)
// ------------------------------------------------------------
model Settings {
  id                 String   @id @default("1")
  collegeName        String   @default("Your College Name")
  collegeAddress     String?
  collegePhone       String?
  collegeEmail       String?
  logoUrl            String?
  currentSession     String   @default("2025-2026")
  receiptPrefix      String   @default("RCPT")
  receiptNextNumber  Int      @default(1)
  studentIdPrefix    String   @default("STU")
  authorizedSignatory String  @default("Accounts Officer")
  updatedAt          DateTime @updatedAt

  @@map("settings")
}
